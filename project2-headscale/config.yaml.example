# Headscale Configuration Template
# Copy this file to /etc/headscale/config.yaml and replace YOUR_PUBLIC_IP
# with your Raspberry Pi's actual public IP address.
#
# Get your public IP with: curl -4 ifconfig.me

---

# The public URL clients use to reach this Headscale server
server_url: http://YOUR_PUBLIC_IP:8443

# Address and port Headscale listens on (0.0.0.0 = all interfaces)
listen_addr: 0.0.0.0:8443

# Internal metrics endpoint (not exposed publicly)
metrics_listen_addr: 127.0.0.1:9090

# gRPC API endpoint (used internally)
grpc_listen_addr: 0.0.0.0:50443
grpc_allow_insecure: false

# Noise protocol key (WireGuard-based encryption between nodes)
noise:
  private_key_path: /var/lib/headscale/noise_private.key

# IP address ranges assigned to mesh nodes
prefixes:
  v4: 100.64.0.0/10     # IPv4 CGNAT range (standard for Tailscale-compatible networks)
  v6: fd7a:115c:a1e0::/48
  allocation: sequential  # Assigns IPs in order as devices join

# DERP relay servers (used when direct connections can't be established)
derp:
  server:
    enabled: false        # Embedded DERP is disabled; using Tailscale's public relays
    region_id: 999
    region_code: "headscale"
    region_name: "Headscale Embedded DERP"
    verify_clients: true
    stun_listen_addr: "0.0.0.0:3478"
    private_key_path: /var/lib/headscale/derp_server_private.key
    automatically_add_embedded_derp_region: true
    ipv4: 198.51.100.1
    ipv6: 2001:db8::1
  # Use Tailscale's public DERP relays for fallback connectivity
  urls:
    - https://controlplane.tailscale.com/derpmap/default
  paths: []
  auto_update_enabled: true
  update_frequency: 3h

disable_check_updates: false

# Nodes that haven't been seen in 30 minutes are considered offline
ephemeral_node_inactivity_timeout: 30m

# Database configuration — SQLite is sufficient for a home/lab setup
database:
  type: sqlite
  debug: false
  gorm:
    prepare_stmt: true
    parameterized_queries: true
    skip_err_record_not_found: true
    slow_threshold: 1000
  sqlite:
    path: /var/lib/headscale/db.sqlite
    write_ahead_log: true
    wal_autocheckpoint: 1000

# TLS/ACME settings — leave blank for HTTP-only local/lab use
acme_url: https://acme-v02.api.letsencrypt.org/directory
acme_email: ""
tls_letsencrypt_hostname: ""
tls_letsencrypt_cache_dir: /var/lib/headscale/cache
tls_letsencrypt_challenge_type: HTTP-01
tls_letsencrypt_listen: ":http"
tls_cert_path: ""
tls_key_path: ""

# Logging level (info is good for normal operation; use debug for troubleshooting)
log:
  level: info
  format: text

# ACL policy — leave blank to allow all nodes to communicate freely
policy:
  mode: file
  path: ""

# DNS settings for the mesh network
dns:
  magic_dns: true                   # Lets devices reach each other by hostname
  base_domain: headscale.net        # e.g., mydevice.headscale.net
  override_local_dns: true
  nameservers:
    global:
      - 1.1.1.1   # Cloudflare DNS
      - 1.0.0.1
  split: {}
  search_domains: []
  extra_records: []

# Unix socket for the headscale CLI to communicate with the daemon
unix_socket: /var/run/headscale/headscale.sock
unix_socket_permission: "0770"

# Logtail (Tailscale's logging service) — disabled for self-hosted use
logtail:
  enabled: false

randomize_client_port: false

# Taildrop — allows file sharing between mesh nodes
taildrop:
  enabled: true
